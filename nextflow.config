params {
    // ---- Input / Output ----------------------------------------------------
    feature_table        = "${projectDir}/data/feature_table.biom"
    meta_table           = "${projectDir}/data/meta_table.csv"
    taxonomy_table       = ""
    input_format         = "biom"                 // biom | tsv | gtdb
    output_dir           = "${projectDir}/results"
    scripts_dir          = "/opt/ecology-scripts"

    // ---- Filtering ---------------------------------------------------------
    min_library_size     = 5000
    exclude_column       = ""
    exclude_values       = ""

    // ---- Grouping ----------------------------------------------------------
    groups_column             = ""
    groups_paste_columns      = ""
    type_column               = ""
    type2_column              = ""
    type2_levels              = ""

    // ---- Core microbiome ---------------------------------------------------
    which_level           = "Phylum"
    label                 = "analysis"
    prevalence_min        = 0.85
    what_detection        = "absolute"            // absolute | relative
    detection_steps       = 20
    detection_range_min   = -1                    // -1 = auto
    detection_range_max   = -1                    // -1 = auto

    // ---- Output options ----------------------------------------------------
    merge_parquet         = false

}

docker {
    enabled    = true
    runOptions = '-u $(id -u):$(id -g)'
}

process {
    container = 'reubenduncan/ecologyflow-core:latest'
}
